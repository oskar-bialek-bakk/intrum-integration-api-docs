        <mxCell id="m9" value="Konsumpcja komunikatu transformacji" style="endArrow=block;endFill=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="630" y="490" as="sourcePoint"/>
            <mxPoint x="880" y="490" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m10" value="SetImportStep(Transformation, Done)" style="endArrow=block;endFill=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="880" y="520" as="sourcePoint"/>
            <mxPoint x="380" y="520" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m11" value="EnqueImportMessage (komunikaty DM)" style="endArrow=block;endFill=1;fontSize=10;" edge="1" parent="1">
