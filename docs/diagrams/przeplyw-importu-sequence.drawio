            <mxPoint x="380" y="225" as="sourcePoint"/>
            <mxPoint x="130" y="225" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Note: Walidacja -->
        <mxCell id="n1" value="Walidacja" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="270" width="100" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="m5" value="DebtImportQueue_ImportValidation" style="endArrow=block;endFill=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
