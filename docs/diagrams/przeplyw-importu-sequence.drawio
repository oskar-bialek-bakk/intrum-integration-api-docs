        <!-- Note: Konsumpcja -->
        <mxCell id="n3" value="Konsumpcja" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="580" width="110" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="m12" value="Zapis komunikatów do DEBT Manager" style="endArrow=block;endFill=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="380" y="630" as="sourcePoint"/>
            <mxPoint x="1110" y="630" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Note: Finalizacja -->
        <mxCell id="n4" value="Finalizacja" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="660" width="100" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="m13" value="DebtImportQueue_ImportFinalization" style="endArrow=block;endFill=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="380" y="710" as="sourcePoint"/>
            <mxPoint x="630" y="710" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m14" value="Konsumpcja komunikatu finalizacji" style="endArrow=block;endFill=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="630" y="740" as="sourcePoint"/>
            <mxPoint x="880" y="740" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m15" value="SetImportStep(Finishing, Done)" style="endArrow=block;endFill=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="880" y="770" as="sourcePoint"/>
            <mxPoint x="380" y="770" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Final status check -->
        <mxCell id="m16" value="GetImportStatus(importId)" style="endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="810" as="sourcePoint"/>
            <mxPoint x="380" y="810" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m17" value="IsFinished = true" style="endArrow=open;endFill=0;dashed=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="380" y="840" as="sourcePoint"/>
            <mxPoint x="130" y="840" as="targetPoint"/>
          </mxGeometry>
