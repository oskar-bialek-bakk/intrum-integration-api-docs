            <mxPoint x="380" y="380" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Note: Transformacja -->
        <mxCell id="n2" value="Transformacja" style="shape=note;whiteSpace=wrap;size=14;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="410" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="m8" value="DebtImportQueue_ImportTransformation" style="endArrow=block;endFill=1;fontSize=10;" edge="1" parent="1">
