<mxfile>
  <diagram name="Przepływ importu" id="seq1">
    <mxGraphModel dx="1200" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Participants -->
        <mxCell id="p1" value="System zewnętrzny" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#4a9eff;fontColor=#ffffff;strokeColor=#2e7bcf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="140" height="830" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="Integration API" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#26a269;fontColor=#ffffff;strokeColor=#1a7a4c;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="40" width="140" height="830" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="RabbitMQ" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#e5a50a;fontColor=#ffffff;strokeColor=#b8840a;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="40" width="140" height="830" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="Worker Service" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#c061cb;fontColor=#ffffff;strokeColor=#9141a0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="40" width="140" height="830" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="DEBT Manager DB" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#c061cb;fontColor=#ffffff;strokeColor=#9141a0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1040" y="40" width="140" height="830" as="geometry"/>
        </mxCell>

        <!-- 1. Import request -->
        <mxCell id="m1" value="ImportFromFileUpload / ImportFromFileShare" style="endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="110" as="sourcePoint"/>
            <mxPoint x="380" y="110" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m2" value="importId (GUID)" style="endArrow=open;endFill=0;dashed=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="380" y="140" as="sourcePoint"/>
            <mxPoint x="130" y="140" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Polling box -->
        <mxCell id="loop1" value="loop   Polling statusu" style="shape=umlFrame;whiteSpace=wrap;width=180;height=20;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="165" width="400" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="m3" value="GetImportStatus(importId)" style="endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="200" as="sourcePoint"/>
            <mxPoint x="380" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m4" value="CurrentStep, IsFinished" style="endArrow=open;endFill=0;dashed=1;fontSize=11;" edge="1" parent="1">
