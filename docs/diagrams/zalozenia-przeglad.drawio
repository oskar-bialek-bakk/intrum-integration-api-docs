        </mxCell>
        <mxCell id="9" value="Finalizacja" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="sub1">
          <mxGeometry x="50" y="230" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- Edges: main flow -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="2" target="3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e1l" value="REST API" style="edgeLabel;fontSize=11;" vertex="1" connectable="0" parent="e1">
