<mxfile>
  <diagram name="Przegląd importu" id="overview1">
    <mxGraphModel dx="800" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Main flow (left column) -->
        <mxCell id="2" value="System zewnętrzny / IT klienta" style="rounded=1;whiteSpace=wrap;fillColor=#4a9eff;fontColor=#ffffff;strokeColor=#2e7bcf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
