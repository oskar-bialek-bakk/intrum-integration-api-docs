        <mxCell id="4" value="Kolejki (RabbitMQ + SQL)" style="rounded=1;whiteSpace=wrap;fillColor=#e5a50a;fontColor=#ffffff;strokeColor=#b8840a;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="240" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="5" value="Worker Services" style="rounded=1;whiteSpace=wrap;fillColor=#c061cb;fontColor=#ffffff;strokeColor=#9141a0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="340" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="6" value="DEBT Manager" style="rounded=1;whiteSpace=wrap;fillColor=#26a269;fontColor=#ffffff;strokeColor=#1a7a4c;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="540" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- Subgraph: Kroki importu -->
        <mxCell id="sub1" value="Kroki importu (opcjonalnie przejmowane przez IT klienta)" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="120" width="260" height="330" as="geometry"/>
        </mxCell>
        <mxCell id="7" value="Walidacja" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="sub1">
          <mxGeometry x="50" y="50" width="160" height="50" as="geometry"/>
